generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  /// Top tier. Full access to every tenant-scoped feature plus user
  /// administration. The role today's "admins" were upgraded into during
  /// the OWNER/ADMIN split — there can be more than one OWNER per org.
  OWNER
  /// Middle tier. Can create/edit users (RECRUITER + ADMIN only — cannot
  /// promote anyone to OWNER) and manage Branding, Announcements, Tags,
  /// Audit history (own org), and Knowledge approvals. Locked out of
  /// Custom fields, Choice options, AI provider, and other deep settings.
  ADMIN
  /// Default tier — everything a recruiter does day-to-day.
  RECRUITER
}

enum JobStatus {
  OPEN
  CLOSED
  DRAFT
}

enum Stage {
  APPLIED
  SCREEN
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

/// Status of the AI batch processing for a candidate.
/// Chrome-extension imports start as PENDING. A background worker
/// (scripts/process-ai-queue.ts) picks them up and walks them through
/// PROCESSING → READY (or FAILED). Candidates added via PDF resume
/// upload run the AI synchronously and never enter the queue, so their
/// status stays NONE.
enum AIProcessingStatus {
  NONE
  PENDING
  PROCESSING
  READY
  FAILED
}


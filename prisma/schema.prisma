/// Direction of an EmailLog row relative to the ATS-side user. OUTBOUND
/// = we sent it (composer or recruiter's own Outlook captured via the
/// extension). INBOUND = we received it (candidate's reply captured via
/// the extension or, future, an inbound webhook).
enum EmailDirection {
  OUTBOUND
  INBOUND
}

/// How a given EmailLog row got into our database. Lets the timeline UI
/// badge rows by provenance and gives the future webhook integration a
/// clean way to dedupe against extension-captured copies.
enum EmailSource {
  COMPOSER // sent via the ATS email composer (/candidates/[id])
  EXTENSION_OUTLOOK // captured via the Chrome extension on Outlook web
  EXTENSION_GMAIL // captured via the Chrome extension on Gmail (future)
  WEBHOOK // inbound from Resend/Mailgun webhook (future)
  OAUTH_GMAIL // pulled from a connected Gmail account (future)
  OAUTH_OUTLOOK // pulled from a connected Outlook account (future)
  MANUAL // pasted in by hand (future)
}


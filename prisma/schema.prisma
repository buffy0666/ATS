generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RECRUITER
}

enum JobStatus {
  OPEN
  CLOSED
  DRAFT
}

enum Stage {
  APPLIED
  SCREEN
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum ContactRole {
  DECISION_MAKER
  INFLUENCER
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  FORMER
}

enum ContactStatus {
  ACTIVE
  LEFT_COMPANY
  DO_NOT_CONTACT
}

enum CompanySize {
  ONE_TO_TEN
  ELEVEN_TO_FIFTY
  FIFTY_ONE_TO_TWO_HUNDRED
  TWO_HUNDRED_ONE_TO_FIVE_HUNDRED
  FIVE_HUNDRED_ONE_TO_ONE_THOUSAND
  ONE_THOUSAND_PLUS
}

enum RevenueBand {
  UNDER_1M
  ONE_TO_10M
  TEN_TO_50M
  FIFTY_TO_250M
  TWO_FIFTY_M_TO_1B
  OVER_1B
}

enum EmailStatus {
  SENT
  FAILED
}

enum WorkAuth {
  US_CITIZEN
  GREEN_CARD
  H1B
  H1B_TRANSFER
  OPT
  STEM_OPT
  CPT
  TN
  L1
  L2
  E3
  O1
  OTHER_VISA
  NEEDS_SPONSORSHIP
  NOT_AUTHORIZED
}

enum Seniority {
  INTERN
  ENTRY
  JUNIOR
  MID
  SENIOR
  STAFF
  PRINCIPAL
  LEAD
  MANAGER
  SENIOR_MANAGER
  DIRECTOR
  VP
  C_LEVEL
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  CONTRACT_TO_HIRE
  TEMPORARY
  INTERNSHIP
  FREELANCE
}

enum RemotePref {
  ONSITE
  HYBRID
  REMOTE
}

enum CandidateSource {
  LINKEDIN
  REFERRAL
  JOB_BOARD
  AGENCY
  INBOUND
  OUTBOUND
  CAREER_SITE
  EVENT
  RECRUITER_NETWORK
  OTHER
}

enum CandidateStatus {
  ACTIVE
  PASSIVE
  PLACED
  ON_HOLD
  DO_NOT_CONTACT
  ALUMNI
  BLACKLISTED
}

enum DocumentType {
  RESUME
  COVER_LETTER
  PORTFOLIO
  OFFER_LETTER
  REFERENCE_LETTER
  CERTIFICATION
  TRANSCRIPT
  WORK_SAMPLE
  OTHER
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
  OTHER
}

enum VeteranStatus {
  VETERAN
  NOT_VETERAN
  PROTECTED_VETERAN
  PREFER_NOT_TO_SAY
}

enum DisabilityStatus {
  YES
  NO
  PREFER_NOT_TO_SAY
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

enum ListScope {
  PERSONAL
  SHARED
}

enum SequenceStepType {
  EMAIL
  CALL
  TEXT
  LINKEDIN
  TASK
}

enum SequenceStatus {
  ACTIVE
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELED
}

enum StepRunStatus {
  PENDING
  COMPLETED
  SKIPPED
  FAILED
}

enum SavedSearchScope {
  PERSONAL
  SHARED
}

enum InterviewType {
  PHONE_SCREEN
  TECHNICAL
  ONSITE
  FINAL
  CULTURE_FIT
  OTHER
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  NO_SHOW
  RESCHEDULED
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("zinc")
  createdAt DateTime @default(now())

  clients    Client[]
  contacts   ClientContact[]
  candidates Candidate[]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          Role      @default(RECRUITER)
  // Soft-delete / disable flag — preserves audit trail on existing rows
  // while preventing sign-in. Set by the assistant's deactivate_user tool.
  active        Boolean   @default(true)
  deactivatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  jobsCreated         Job[]                 @relation("JobCreator")
  notes               Note[]
  clientsOwned        Client[]              @relation("ClientOwner")
  emailsSent          EmailLog[]
  emailTemplates      EmailTemplate[]       @relation("EmailTemplateCreator")
  candidatesSourced   Candidate[]           @relation("CandidateSourcer")
  candidatesReferred  Candidate[]           @relation("CandidateReferrerUser")
  referencesContacted CandidateReference[]
  documentsUploaded   CandidateDocument[]
  activities          CandidateActivity[]
  tasksCreated        Task[]                @relation("TaskCreator")
  taskAttachments     TaskAttachment[]      @relation("TaskAttachmentUploader")
  lists               CandidateList[]
  listMembersAdded    CandidateListMember[] @relation("ListMemberAdder")
  savedSearches       SavedSearch[]
  sequencesCreated    Sequence[]            @relation("SequenceCreator")
  enrollmentsCreated  SequenceEnrollment[]  @relation("SequenceEnroller")
  stepRunsCompleted   StepRun[]             @relation("StepRunCompleter")
  assistantConversations AssistantConversation[] @relation("AssistantUser")
  assistantToolCalls     AssistantToolCall[]     @relation("AssistantToolCaller")

  // Calendar
  iCalToken             String?              @unique
  interviewsOrganized   Interview[]          @relation("InterviewOrganizer")
  interviewAttendances  InterviewAttendee[]  @relation("InterviewAttendeeUser")
}

model Job {
  id          String    @id @default(cuid())
  title       String
  department  String?
  location    String?
  description String
  status      JobStatus @default(OPEN)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdById  String?
  createdBy    User?         @relation("JobCreator", fields: [createdById], references: [id])
  applications Application[]

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  @@index([status])
  @@index([clientId])
}

model Client {
  id          String       @id @default(cuid())
  name        String
  linkedinUrl String?
  website     String?
  industry    String?
  location    String?
  address     String?
  phone       String?
  companySize CompanySize?
  revenueBand RevenueBand?
  status      ClientStatus @default(ACTIVE)
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  ownerId String?
  owner   User?   @relation("ClientOwner", fields: [ownerId], references: [id])

  contacts ClientContact[]
  jobs     Job[]
  tags     Tag[]

  @@index([status])
  @@index([ownerId])
}

model ClientContact {
  id              String        @id @default(cuid())
  clientId        String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  title           String?
  department      String?
  role            ContactRole?
  linkedinUrl     String?
  status          ContactStatus @default(ACTIVE)
  lastContactedAt DateTime?
  birthday        DateTime?     @db.Date
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  client             Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tags               Tag[]
  candidatesReferred Candidate[] @relation("CandidateReferrerContact")

  @@index([clientId])
  @@index([status])
}

model Candidate {
  id            String  @id @default(cuid())
  email         String  @unique
  firstName     String
  lastName      String
  preferredName String?
  pronouns      String?

  // Contact
  phone          String?
  alternateEmail String?
  alternatePhone String?

  // Location
  locationCity      String?
  locationState     String?
  locationCountry   String?
  timezone          String?
  willingToRelocate Boolean @default(false)

  // Work authorization
  workAuthorization   WorkAuth?
  requiresSponsorship Boolean   @default(false)

  // Links
  resumeUrl    String?
  linkedinUrl  String?
  githubUrl    String?
  portfolioUrl String?
  otherUrls    String[] @default([])

  // Career snapshot
  currentTitle    String?
  currentCompany  String?
  yearsExperience Int?
  seniority       String?

  // Compensation
  desiredSalaryMin Int?
  desiredSalaryMax Int?
  currentSalary    Int?
  salaryCurrency   String @default("USD")

  // Availability
  availableFrom      DateTime?
  noticePeriodDays   Int?
  employmentTypePref EmploymentType[] @default([])
  remotePref         RemotePref[]     @default([])

  // Focus
  industries  String[] @default([])
  specialties String[] @default([])

  // Source & ownership
  // `source` and `seniority` used to be Prisma enums; they're now free-form
  // strings backed by the editable ChoiceOption registry (field="candidate.source"
  // and "candidate.seniority"). The enums remain in schema as TS type exports
  // so existing imports keep resolving.
  source              String?
  sourceDetail        String?
  sourcedById         String?
  sourcedBy           User?            @relation("CandidateSourcer", fields: [sourcedById], references: [id])
  referredByUserId    String?
  referredByUser      User?            @relation("CandidateReferrerUser", fields: [referredByUserId], references: [id])
  referredByContactId String?
  referredByContact   ClientContact?   @relation("CandidateReferrerContact", fields: [referredByContactId], references: [id])
  referredByName      String?

  // Engagement
  status          CandidateStatus @default(ACTIVE)
  rating          Int?
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  unsubscribedAt  DateTime?

  // Resume content
  summary       String?
  skills        String[]  @default([])
  workHistory   Json?
  education     Json?
  parsedAt      DateTime?
  parserVersion String?

  // Plain text extracted from the resume; backs the FTS searchVector column
  // (added via raw SQL migration — Prisma cannot describe generated tsvector).
  resumeText String?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications    Application[]
  emails          EmailLog[]
  tags            Tag[]
  references      CandidateReference[]
  documents       CandidateDocument[]
  eeo             CandidateEEO?
  activities      CandidateActivity[]
  listMemberships CandidateListMember[]
  interviews      Interview[]
  enrollments     SequenceEnrollment[]

  @@index([status])
  @@index([sourcedById])
  @@index([locationCity, locationState])
  @@index([currentCompany])
  @@index([seniority])
}

model Application {
  id          String   @id @default(cuid())
  jobId       String
  candidateId String
  stage       Stage    @default(APPLIED)
  rating      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  job         Job                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate   Candidate            @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  notes       Note[]
  emails      EmailLog[]
  interviews  Interview[]
  enrollments SequenceEnrollment[]

  @@unique([jobId, candidateId])
  @@index([jobId, stage])
}

model Note {
  id            String   @id @default(cuid())
  applicationId String
  authorId      String
  body          String
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  author      User        @relation(fields: [authorId], references: [id])

  @@index([applicationId])
}

model KnowledgeItem {
  id        String   @id @default(cuid())
  name      String
  type      String // "document" | "link"
  url       String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailTemplate {
  id            String         @id @default(cuid())
  name          String
  subject       String
  body          String
  createdById   String?
  createdBy     User?          @relation("EmailTemplateCreator", fields: [createdById], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sequenceSteps SequenceStep[]

  @@index([createdById])
}

model EmailLog {
  id            String  @id @default(cuid())
  candidateId   String?
  applicationId String?
  fromUserId    String

  to       String
  cc       String[] @default([])
  bcc      String[] @default([])
  replyTo  String?
  subject  String
  bodyText String?
  bodyHtml String?

  provider          String
  providerMessageId String?
  status            EmailStatus @default(SENT)
  errorMessage      String?

  sentAt DateTime @default(now())

  candidate   Candidate?   @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  fromUser    User         @relation(fields: [fromUserId], references: [id])
  stepRun     StepRun?

  @@index([candidateId, sentAt])
  @@index([applicationId, sentAt])
  @@index([fromUserId])
}

model CandidateReference {
  id            String    @id @default(cuid())
  candidateId   String
  firstName     String
  lastName      String
  relationship  String?
  company       String?
  title         String?
  email         String?
  phone         String?
  notes         String?
  contactedAt   DateTime?
  contactedById String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  contactedBy User?     @relation(fields: [contactedById], references: [id])

  @@index([candidateId])
}

model CandidateDocument {
  id           String       @id @default(cuid())
  candidateId  String
  type         DocumentType
  name         String
  url          String
  notes        String?
  uploadedById String?
  uploadedAt   DateTime     @default(now())

  candidate  Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  uploadedBy User?     @relation(fields: [uploadedById], references: [id])

  @@index([candidateId])
  @@index([candidateId, type])
}

// EEO data is legally sensitive; gate access at the application layer
// and never join into search/match logic.
model CandidateEEO {
  id               String            @id @default(cuid())
  candidateId      String            @unique
  gender           Gender?
  race             String?
  veteranStatus    VeteranStatus?
  disabilityStatus DisabilityStatus?
  providedAt       DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model CandidateActivity {
  id          String   @id @default(cuid())
  candidateId String
  type        String
  description String?
  metadata    Json?
  userId      String?
  createdAt   DateTime @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])

  @@index([candidateId, createdAt])
}

// Shared admin task list. Description stores raw HTML — writers and readers
// are both admins (gated in the route), so the trust boundary makes this safe.
model Task {
  id          String     @id @default(cuid())
  name        String
  description String?
  status      TaskStatus @default(NOT_STARTED)
  createdById String?
  createdBy   User?      @relation("TaskCreator", fields: [createdById], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  attachments TaskAttachment[]

  @@index([status])
  @@index([updatedAt])
  @@index([createdAt])
}

model TaskAttachment {
  id           String   @id @default(cuid())
  taskId       String
  name         String
  url          String
  size         Int
  mimeType     String?
  uploadedById String?
  uploadedAt   DateTime @default(now())

  task       Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation("TaskAttachmentUploader", fields: [uploadedById], references: [id])

  @@index([taskId])
}

// Recruiter-curated candidate lists ("Active Engineering", "Cold pipeline 2026", etc).
// Personal lists are visible to their owner only; SHARED lists are visible to all users.
model CandidateList {
  id          String    @id @default(cuid())
  name        String
  description String?
  ownerId     String
  scope       ListScope @default(PERSONAL)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner   User                  @relation(fields: [ownerId], references: [id])
  members CandidateListMember[]

  @@index([ownerId])
  @@index([scope])
}

model CandidateListMember {
  id          String   @id @default(cuid())
  listId      String
  candidateId String
  addedById   String?
  addedAt     DateTime @default(now())

  list      CandidateList @relation(fields: [listId], references: [id], onDelete: Cascade)
  candidate Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  addedBy   User?         @relation("ListMemberAdder", fields: [addedById], references: [id])

  @@unique([listId, candidateId])
  @@index([candidateId])
}

// A named, reusable filter set on /candidates. paramsString stores the raw
// URL query (e.g. "q=react&status=ACTIVE,PASSIVE&tag=Senior") so loading a
// saved search is a navigation to ?<paramsString>.
model SavedSearch {
  id           String           @id @default(cuid())
  name         String
  ownerId      String
  scope        SavedSearchScope @default(PERSONAL)
  paramsString String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  owner User @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([scope])
}

model Interview {
  id            String          @id @default(cuid())
  applicationId String?
  candidateId   String
  title         String
  type          InterviewType
  status        InterviewStatus @default(SCHEDULED)
  startAt       DateTime
  endAt         DateTime
  timezone      String?
  location      String?
  videoUrl      String?
  description   String?
  organizerId   String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  application Application?        @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  candidate   Candidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  organizer   User                @relation("InterviewOrganizer", fields: [organizerId], references: [id])
  attendees   InterviewAttendee[]

  @@index([candidateId, startAt])
  @@index([organizerId, startAt])
  @@index([startAt])
  @@index([status])
}

model InterviewAttendee {
  id          String  @id @default(cuid())
  interviewId String
  userId      String?
  email       String
  name        String?
  role        String?

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  user      User?     @relation("InterviewAttendeeUser", fields: [userId], references: [id])

  @@index([interviewId])
  @@index([userId])
}

// User-editable lookup registry for "soft" choice fields (Candidate.source,
// Candidate.seniority, etc). The candidate column stores the option's `name`
// directly — rename is an updateMany, delete sets affected records to null.
model ChoiceOption {
  id        String   @id @default(cuid())
  field     String
  name      String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([field, name])
  @@index([field, active, sortOrder])
}

// ----- Sequences (multi-step cadences) -----

model Sequence {
  id          String         @id @default(cuid())
  name        String
  description String?
  status      SequenceStatus @default(ACTIVE)
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  createdBy   User?                @relation("SequenceCreator", fields: [createdById], references: [id])
  steps       SequenceStep[]
  enrollments SequenceEnrollment[]

  @@index([status])
  @@index([createdById])
}

model SequenceStep {
  id        String           @id @default(cuid())
  sequenceId String
  order      Int
  type       SequenceStepType
  delayDays  Int              @default(0)

  // EMAIL-only
  emailTemplateId String?
  subject         String?
  body            String?

  // Manual-task-only (CALL/TEXT/LINKEDIN/TASK)
  taskTitle        String?
  taskInstructions String?

  sequence      Sequence       @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  emailTemplate EmailTemplate? @relation(fields: [emailTemplateId], references: [id], onDelete: SetNull)
  runs          StepRun[]

  @@unique([sequenceId, order])
  @@index([sequenceId])
}

model SequenceEnrollment {
  id            String           @id @default(cuid())
  sequenceId    String
  candidateId   String
  applicationId String?
  enrolledById  String?
  status        EnrollmentStatus @default(ACTIVE)
  startedAt     DateTime         @default(now())
  pausedAt      DateTime?
  completedAt   DateTime?

  sequence    Sequence     @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  candidate   Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  enrolledBy  User?        @relation("SequenceEnroller", fields: [enrolledById], references: [id])
  stepRuns    StepRun[]

  @@unique([sequenceId, candidateId])
  @@index([candidateId])
  @@index([status])
  @@index([enrolledById, status])
}

model StepRun {
  id           String        @id @default(cuid())
  enrollmentId String
  stepId       String
  scheduledFor DateTime
  status       StepRunStatus @default(PENDING)

  // EMAIL only
  emailLogId        String? @unique
  resendScheduledId String?

  // Manual task only
  completedAt   DateTime?
  completedById String?
  outcomeNote   String?

  errorMessage String?

  enrollment  SequenceEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  step        SequenceStep       @relation(fields: [stepId], references: [id], onDelete: Cascade)
  emailLog    EmailLog?          @relation(fields: [emailLogId], references: [id], onDelete: SetNull)
  completedBy User?              @relation("StepRunCompleter", fields: [completedById], references: [id])

  @@index([scheduledFor, status])
  @@index([enrollmentId])
}

// ----- AI assistant -----
//
// Conversation = one chat thread between a user and the assistant.
// Message = one turn in that thread (user / assistant / tool / system).
// ToolCall = an audit row for every tool the assistant invoked, including
// args + result + any error, so we can replay and review what the AI did.

enum AssistantRole {
  USER
  ASSISTANT
  TOOL
  SYSTEM
}

model AssistantConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User               @relation("AssistantUser", fields: [userId], references: [id])
  messages AssistantMessage[]

  @@index([userId, updatedAt])
}

model AssistantMessage {
  id             String        @id @default(cuid())
  conversationId String
  role           AssistantRole
  content        String
  // For assistant turns that requested tool calls. Shape:
  //   [{ id: string, name: string, arguments: object }]
  toolCalls      Json?
  // For TOOL messages: which assistant tool_call id this is a response to.
  toolCallId     String?
  createdAt      DateTime      @default(now())

  conversation  AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolAuditLogs AssistantToolCall[]

  @@index([conversationId, createdAt])
}

model AssistantToolCall {
  id           String   @id @default(cuid())
  messageId    String
  userId       String
  toolName     String
  arguments    Json
  result       Json?
  isError      Boolean  @default(false)
  errorMessage String?
  createdAt    DateTime @default(now())

  message AssistantMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User             @relation("AssistantToolCaller", fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([toolName])
}

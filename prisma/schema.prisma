/// Catalog of events captured in AuditLog. CREATE/UPDATE/DELETE are emitted
/// automatically by the Prisma audit extension for allowlisted models;
/// everything else is recorded explicitly by lib/audit/log.ts callers.
enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  ROLE_CHANGE
  IMPERSONATE_START
  IMPERSONATE_END
  TOKEN_MINT
  TOKEN_REVOKE
  USER_INVITE
  USER_DEACTIVATE
  USER_REACTIVATE
  AI_CONFIG_CHANGE
  EXPORT
  // Two duplicate candidate records merged into one (see
  // src/app/candidates/merge/actions.ts). Appended additively — the
  // shared DB needs `ALTER TYPE "AuditAction" ADD VALUE IF NOT EXISTS
  // 'CANDIDATE_MERGE'` applied before this value can be written.
  CANDIDATE_MERGE
}

/// A tenant in the multi-tenant SaaS sense — every business object (Client,
/// Candidate, Job, ...) belongs to exactly one Organization. A user belongs
/// to exactly one Organization too (1:1) for now; we can M:N later if a
/// user needs to consult across firms.
///
/// Cascade is set on most child relations so deleting an Organization
/// scrubs every row that belongs to it. That's intentional — it's the
/// "delete my account" path for a SaaS customer.
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  // Workspace logo — public URL (Vercel Blob in prod, /uploads/... in dev).
  // Optional; sidebar + dashboard fall back to the org name when null.
  logoUrl   String?
  // Demo tenant flag. The /api/cron/cleanup-demo-orgs job hard-deletes
  // demo orgs older than 14 days; cascade wipes every scoped child.
  isDemo    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The user who created the org. Has implicit OWNER privileges that
  // can't be revoked by other admins (so a co-admin can't lock the
  // founder out).
  ownerUserId String? @unique
  ownerUser   User?   @relation("OrganizationOwner", fields: [ownerUserId], references: [id])

  // Back-relations — top-level scoped models. Child rows (e.g.
  // CandidateDocument, SequenceStep, AssistantMessage) inherit isolation
  // through their parent's organizationId and are scoped in later
  // phases; for Phase 1 these top-level back-relations are enough.
  users                  User[]                  @relation("OrganizationMembers")
  tags                   Tag[]
  apiTokens              ApiToken[]
  aiConfig               AIConfig?
  jobs                   Job[]
  clients                Client[]
  clientContacts         ClientContact[]
  candidates             Candidate[]
  applications           Application[]
  noteThreads            Note[]
  knowledgeItems         KnowledgeItem[]
  emailTemplates         EmailTemplate[]
  emails                 EmailLog[]
  contactLogs            ContactLog[]
  tasks                  Task[]
  candidateLists         CandidateList[]
  savedSearches          SavedSearch[]
  profileLayouts         ProfileLayout[]
  interviews             Interview[]
  choiceOptions          ChoiceOption[]
  sequences              Sequence[]
  assistantConversations AssistantConversation[]
  customFields           CustomField[]
  invitations            Invitation[]
  impersonationSessions  ImpersonationSession[]  @relation("ImpersonationTargetOrg")
  auditLogs              AuditLog[]
  announcements          Announcement[]
  announcementTargets    AnnouncementTarget[]
  importMappings         ImportMapping[]
  candidateImports       CandidateImport[]
}

model Tag {
  id        String   @id @default(cuid())
  // Still globally unique during Phase 1-5; Phase 6 swaps to
  // @@unique([organizationId, name]) so two orgs can independently have a
  // "Senior" tag. Existing queries still pass `where: { name }` until then.
  name      String   @unique
  color     String   @default("zinc")
  createdAt DateTime @default(now())

  // Multi-tenant scope — nullable during the staged migration; Phase 6
  // flips it NOT NULL once every query writes it.
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  clients    Client[]
  contacts   ClientContact[]
  candidates Candidate[]

  @@index([organizationId])
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  passwordHash    String
  // Within-tenant role: ADMIN can configure settings, manage users, view
  // tasks; RECRUITER is the regular recruiter. Orthogonal to
  // `isPlatformAdmin` below — a single user can be both (e.g. the SaaS
  // operator dogfooding their own tenant).
  role            Role      @default(RECRUITER)
  // Platform admin tier — sees /platform/* routes that span all orgs.
  // Used by the SaaS operator to manage tenants. Bootstrapped from the
  // PLATFORM_ADMIN_EMAILS env var on every sign-in so a typo in the DB
  // can't lock you out. See requirePlatformAdmin() in lib/auth-utils.ts.
  isPlatformAdmin Boolean   @default(false)
  // Soft-delete / disable flag — preserves audit trail on existing rows
  // while preventing sign-in. Set by the assistant's deactivate_user tool.
  active          Boolean   @default(true)
  deactivatedAt   DateTime?

  // --- Technology section (admin-managed on /users/[id]) ---
  // Free-text notes about the user's tooling/setup.
  technologyComments String?
  // Phone system(s) the user is on. Plain strings from the app-defined
  // option list (PHONE_SYSTEM_OPTIONS in src/app/users/user-fields.ts);
  // "Other" is just one of the options. Stored as a scalar list so a user
  // can be on more than one.
  phoneSystems       String[] @default([])
  // The actual phone number the user dials from.
  phoneNumber        String?
  // A second free-text notes field for the Technology section.
  technologyNotes    String?

  // --- User Profile section ---
  // Free-text profile notes.
  profileComments String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobsCreated            Job[]                    @relation("JobCreator")
  notes                  Note[]
  clientsOwned           Client[]                 @relation("ClientOwner")
  emailsSent             EmailLog[]
  contactLogsLogged      ContactLog[]             @relation("ContactLogLogger")
  emailTemplates         EmailTemplate[]          @relation("EmailTemplateCreator")
  candidatesSourced      Candidate[]              @relation("CandidateSourcer")
  candidatesReferred     Candidate[]              @relation("CandidateReferrerUser")
  referencesContacted    CandidateReference[]
  documentsUploaded      CandidateDocument[]
  certificationsVerified CandidateCertification[] @relation("CertificationVerifier")
  activities             CandidateActivity[]
  tasksCreated           Task[]                   @relation("TaskCreator")
  tasksAssigned          Task[]                   @relation("TaskAssignee")
  knowledgeItemsCreated  KnowledgeItem[]          @relation("KnowledgeItemCreator")
  knowledgeAttachments   KnowledgeAttachment[]    @relation("KnowledgeAttachmentUploader")
  jobContracts           JobContract[]            @relation("JobContractUploader")
  taskAttachments        TaskAttachment[]         @relation("TaskAttachmentUploader")
  lists                  CandidateList[]
  listMembersAdded       CandidateListMember[]    @relation("ListMemberAdder")
  listAssignments        CandidateListAssignee[]  @relation("ListAssignee")
  listAssignmentsMade    CandidateListAssignee[]  @relation("ListAssigner")
  savedSearches          SavedSearch[]
  profileLayouts         ProfileLayout[]
  sequencesCreated       Sequence[]               @relation("SequenceCreator")
  enrollmentsCreated     SequenceEnrollment[]     @relation("SequenceEnroller")
  stepRunsCompleted      StepRun[]                @relation("StepRunCompleter")
  assistantConversations AssistantConversation[]  @relation("AssistantUser")
  assistantToolCalls     AssistantToolCall[]      @relation("AssistantToolCaller")
  auditEvents            AuditLog[]               @relation("AuditActor")
  announcementsCreated   Announcement[]           @relation("AnnouncementAuthor")

  // Calendar
  iCalToken            String?             @unique
  interviewsOrganized  Interview[]         @relation("InterviewOrganizer")
  interviewAttendances InterviewAttendee[] @relation("InterviewAttendeeUser")

  // API tokens (used by Chrome extension and any future external integrations)
  apiTokens ApiToken[]

  // Phase 4c — invitations
  invitationsCreated  Invitation[] @relation("InvitationCreator")
  invitationsAccepted Invitation[] @relation("InvitationAcceptor")

  // Phase 4d — impersonation audit log. Two relations: one for sessions
  // I (the platform admin) initiated, and one for sessions in which I
  // was the target (so support engagements show up in my own audit
  // history). The target relation should usually be unused — you don't
  // sign in as platform admins to "support" them.
  impersonationsStarted  ImpersonationSession[] @relation("ImpersonationPlatformAdmin")
  impersonationsTargeted ImpersonationSession[] @relation("ImpersonationTarget")

  importMappingsCreated ImportMapping[]     @relation("ImportMappingCreator")
  importMappingsUpdated ImportMapping[]     @relation("ImportMappingUpdater")
  candidateImportsRun   CandidateImport[]   @relation("CandidateImporter")
  mailboxConnections    MailboxConnection[]

  // Multi-tenant: every user belongs to exactly one Organization. Nullable
  // during the staged migration (current users get assigned to the Default
  // Org by scripts/migrate-to-multitenant.ts before Phase 6 flips it NOT
  // NULL). `ownedOrganization` is the reverse side of Organization.ownerUser
  // — set for the user who created their org.
  organizationId    String?
  organization      Organization? @relation("OrganizationMembers", fields: [organizationId], references: [id], onDelete: Cascade)
  ownedOrganization Organization? @relation("OrganizationOwner")

  @@index([organizationId])
}

/// A recruiter's connected sending mailbox (Phase 2 email integration).
/// Currently Gmail only. Stores the OAuth refresh token (AES-256-GCM
/// encrypted via lib/crypto) so the app can mint short-lived access tokens
/// and send "on behalf of" the user, from their real address. One active
/// connection per (user, provider).
model MailboxConnection {
  id                    String   @id @default(cuid())
  userId                String
  provider              String // "google" (future: "microsoft")
  email                 String // the connected mailbox address
  // AES-256-GCM encrypted OAuth refresh token (lib/crypto blob format).
  refreshTokenEncrypted String
  // Space-delimited granted scopes, for diagnostics + re-consent checks.
  scope                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

/// Pending magic-link invitations. Created when either (a) a platform
/// admin spins up a new tenant for a customer at /platform/organizations/new
/// or (b) a tenant ADMIN invites a teammate at /users/new.
///
/// The plaintext token is shown once (embedded in the email URL); we store
/// only its SHA-256 hash. Tokens expire after 7 days and are single-use
/// (acceptedAt flips on accept, after which lookups by tokenHash return a
/// "this invitation has already been used" error).
model Invitation {
  id          String @id @default(cuid())
  email       String
  tokenHash   String @unique
  tokenPrefix String // first 12 chars of the token for UI display
  role        Role   @default(RECRUITER)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Whoever clicked the "send invite" button. Null for invites the
  // platform admin sends to brand-new orgs (the inviter is a different
  // tenant from the invitee).
  invitedByUserId String?
  invitedBy       User?   @relation("InvitationCreator", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  // True when the invite is for the org's first user → they become both
  // the founding ADMIN and the Organization.ownerUserId on accept. Set by
  // the platform-admin "create new tenant" flow.
  asOwner Boolean @default(false)

  expiresAt      DateTime
  acceptedAt     DateTime?
  acceptedUserId String?
  acceptedUser   User?     @relation("InvitationAcceptor", fields: [acceptedUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([email])
  @@index([expiresAt])
}

/// Audit row for every time a platform admin signs in as a tenant user.
///
/// We never delete these — they're the audit trail. `endedAt` is set when
/// the impersonator clicks the banner's "exit" button or when the session
/// auto-expires (default 30 min via `expiresAt`).
///
/// Defense in depth: a separate `requireNotImpersonating()` guard runs on
/// dangerous routes (delete org, change billing, etc.) so even a logged-in
/// impersonator can't act on the platform side.
model ImpersonationSession {
  id                  String       @id @default(cuid())
  platformAdminUserId String
  platformAdmin       User         @relation("ImpersonationPlatformAdmin", fields: [platformAdminUserId], references: [id])
  targetUserId        String
  targetUser          User         @relation("ImpersonationTarget", fields: [targetUserId], references: [id])
  targetOrgId         String
  targetOrg           Organization @relation("ImpersonationTargetOrg", fields: [targetOrgId], references: [id], onDelete: Cascade)
  reason              String? // optional free-text from the platform admin

  startedAt DateTime  @default(now())
  endedAt   DateTime?
  // Hard cap regardless of whether endedAt is set — sessions older than
  // this are treated as inactive even if endedAt is null (the user closed
  // the tab without clicking exit).
  expiresAt DateTime

  @@index([platformAdminUserId, endedAt])
  @@index([targetUserId])
  @@index([startedAt])
}

/// Hashed API tokens for external integrations (Chrome extension etc.).
/// The plaintext token is shown once at creation time; only the SHA-256
/// hash is stored. `tokenPrefix` is the first 12 chars of the token, kept
/// to help users identify which token is which in the UI.
model ApiToken {
  id          String    @id @default(cuid())
  userId      String
  name        String
  tokenHash   String    @unique
  tokenPrefix String
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Denormalized org scope. Tokens are user-owned, so org is transitive
  // via user — but writing it on the row directly means the external
  // candidate-ingest endpoint can resolve org with one query, not two.
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([organizationId])
}

/// AI-provider configuration. Was a global singleton (id="default") in the
/// single-tenant era; now ONE PER ORGANIZATION so each tenant brings their
/// own provider + key. The API key is AES-256-GCM encrypted using a key
/// derived from AUTH_SECRET — the DB never holds plaintext keys.
///
/// `organizationId` is nullable during the staged migration; the legacy
/// id="default" row is preserved and gets reassigned to the Default Org by
/// the migration script.
model AIConfig {
  id              String   @id @default(cuid())
  provider        String // "ollama" | "openai" | "anthropic" | "grok"
  model           String
  baseUrl         String?
  apiKeyEncrypted String?
  /// How the stored secret is sent: "apiKey" (default) or "oauth" (Bearer token,
  /// currently only honored by the Anthropic provider). Other providers ignore it.
  authMode        String?  @default("apiKey")
  timeoutMs       Int?
  updatedAt       DateTime @updatedAt
  updatedById     String?

  organizationId String?       @unique
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Job {
  id            String    @id @default(cuid())
  title         String
  department    String?
  location      String?
  description   String
  status        JobStatus @default(OPEN)
  // Free-form notes on how this role is filled (steps, interview loop, etc).
  hiringProcess String?
  // Engagement tier: "Urgent" | "Normal" | "Luxury". Free-form string with a
  // fixed picker in the UI; nullable for back-compat with existing rows.
  jobType       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  createdById    String?
  createdBy      User?              @relation("JobCreator", fields: [createdById], references: [id])
  applications   Application[]
  hiringManagers JobHiringManager[]
  contracts      JobContract[]
  lists          CandidateListJob[]

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  // Compensation + placement fee. Estimated fee dollars are derived on read
  // as salaryLow * placementFeePercent / 100, so only inputs are stored.
  salaryLow           Int?
  salaryHigh          Int?
  placementFeePercent Int?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([clientId])
  @@index([organizationId])
}

// Hiring-side contacts for a job. Many per job. `chat` is free-form (a Teams/
// Slack/WhatsApp handle or a chat URL).
model JobHiringManager {
  id        String   @id @default(cuid())
  jobId     String
  name      String
  email     String?
  phone     String?
  chat      String?
  comments  String?
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

// Contract documents attached to a job. Many per job. Blob stored via
// lib/uploads (Vercel Blob in prod, public/uploads in dev).
model JobContract {
  id           String   @id @default(cuid())
  jobId        String
  name         String
  url          String
  size         Int
  mimeType     String?
  uploadedById String?
  uploadedAt   DateTime @default(now())

  job        Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation("JobContractUploader", fields: [uploadedById], references: [id])

  @@index([jobId])
}

model Client {
  id          String       @id @default(cuid())
  name        String
  linkedinUrl String?
  website     String?
  industry    String?
  location    String?
  address     String?
  phone       String?
  companySize CompanySize?
  revenueBand RevenueBand?
  status      ClientStatus @default(ACTIVE)
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  ownerId String?
  owner   User?   @relation("ClientOwner", fields: [ownerId], references: [id])

  contacts       ClientContact[]
  jobs           Job[]
  tags           Tag[]
  knowledgeItems KnowledgeItem[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([ownerId])
  @@index([organizationId])
}

model ClientContact {
  id              String        @id @default(cuid())
  clientId        String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  title           String?
  department      String?
  role            ContactRole?
  linkedinUrl     String?
  status          ContactStatus @default(ACTIVE)
  lastContactedAt DateTime?
  birthday        DateTime?     @db.Date
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  client             Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tags               Tag[]
  candidatesReferred Candidate[] @relation("CandidateReferrerContact")

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
  @@index([organizationId])
}

model Candidate {
  id            String  @id @default(cuid())
  // Email is unique PER ORGANIZATION, not globally — the same person can
  // legitimately be a candidate at two different recruiting firms on the
  // platform. Was `@unique` (global) pre-Phase-6, which blocked capturing
  // an email/candidate into org B if it already existed in org A. The
  // compound @@unique([organizationId, email]) at the bottom of this model
  // enforces per-tenant uniqueness instead.
  email         String
  firstName     String
  lastName      String
  preferredName String?
  pronouns      String?

  // Contact
  phone          String?
  alternateEmail String?
  alternatePhone String?

  // Location
  locationCity      String?
  locationState     String?
  locationCountry   String?
  timezone          String?
  willingToRelocate Boolean @default(false)

  // Work authorization
  workAuthorization   WorkAuth?
  requiresSponsorship Boolean   @default(false)

  // Links
  resumeUrl    String?
  linkedinUrl  String?
  githubUrl    String?
  portfolioUrl String?
  otherUrls    String[] @default([])

  // Career snapshot
  currentTitle    String?
  currentCompany  String?
  yearsExperience Int?
  seniority       String?

  // Compensation
  desiredSalaryMin Int?
  desiredSalaryMax Int?
  currentSalary    Int?
  salaryCurrency   String @default("USD")

  // Availability
  availableFrom      DateTime?
  noticePeriodDays   Int?
  employmentTypePref EmploymentType[] @default([])
  remotePref         RemotePref[]     @default([])

  // Focus
  industries  String[] @default([])
  specialties String[] @default([])

  // Source & ownership
  // `source` and `seniority` used to be Prisma enums; they're now free-form
  // strings backed by the editable ChoiceOption registry (field="candidate.source"
  // and "candidate.seniority"). The enums remain in schema as TS type exports
  // so existing imports keep resolving.
  source              String?
  sourceDetail        String?
  sourcedById         String?
  sourcedBy           User?          @relation("CandidateSourcer", fields: [sourcedById], references: [id])
  referredByUserId    String?
  referredByUser      User?          @relation("CandidateReferrerUser", fields: [referredByUserId], references: [id])
  referredByContactId String?
  referredByContact   ClientContact? @relation("CandidateReferrerContact", fields: [referredByContactId], references: [id])
  referredByName      String?

  // Engagement
  status          CandidateStatus @default(ACTIVE)
  rating          Int?
  // Why the candidate declined / passed — multi-select backed by the
  // ChoiceOption registry (candidate.rejectionReason). Editable per-org
  // in /settings/choices.
  rejectionReasons String[]       @default([])
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  unsubscribedAt  DateTime?

  // Resume content
  summary       String?
  skills        String[]  @default([])
  workHistory   Json?
  education     Json?
  parsedAt      DateTime?
  parserVersion String?

  // LinkedIn activity captured by the Chrome extension (recent posts,
  // comments, reactions). Each item: { kind, text, categories[], when }.
  // Empty for candidates added via PDF resume upload.
  recentActivity Json?

  // Batch AI processing — see AIProcessingStatus comment.
  aiStatus          AIProcessingStatus @default(NONE)
  aiProcessedAt     DateTime?
  aiError           String?
  // Polished resume produced by the AI worker. Shape:
  // { header: {...}, summary, skills, experience: [...], education: [...] }
  aiResumeFacsimile Json?
  // AI-suggested personalization hooks for crafting outreach. Shape:
  // [{ hook: string, source: string, suggestedOpener: string, tone: string }]
  outreachInsights  Json?

  // Plain text extracted from the resume; backs the FTS searchVector column.
  resumeText String?

  // Full-text search vector. The COLUMN is declared here (as Unsupported)
  // so `prisma db push` doesn't try to drop it, but its CONTENT is
  // maintained by a raw-SQL trigger Prisma can't model — see
  // prisma/manual-migrations/*candidate-search-vector* and *fts-*.
  searchVector Unsupported("tsvector")?

  // Raw text scraped from the candidate's LinkedIn profile by the Chrome
  // extension. Kept separate from resumeText so a later PDF resume upload
  // doesn't clobber the LinkedIn capture (and vice versa).
  linkedinPageText String?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications     Application[]
  emails           EmailLog[]
  contactLogs      ContactLog[]
  tags             Tag[]
  references       CandidateReference[]
  educationHistory CandidateEducation[]
  certifications   CandidateCertification[]
  documents        CandidateDocument[]
  eeo              CandidateEEO?
  activities       CandidateActivity[]
  listMemberships  CandidateListMember[]
  interviews       Interview[]
  enrollments      SequenceEnrollment[]
  // Threaded notes (per-application or candidate-level). Named differently
  // from the legacy `notes String?` free-form field above.
  noteThreads      Note[]                   @relation("CandidateNoteThreads")

  // The named CSV import batch this candidate was created by, if any.
  // SetNull so deleting an import record doesn't take its candidates with
  // it. Only stamped on rows the import CREATED — an update-mode import
  // leaves an existing candidate's original provenance intact.
  importId String?
  import   CandidateImport? @relation(fields: [importId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Per-tenant email uniqueness (replaces the old global @unique on email).
  // Two orgs can each have a candidate with the same email; one org can't
  // have two. organizationId is nullable during the staged migration, so
  // Postgres treats NULL org rows as distinct — acceptable until Phase 6
  // flips organizationId NOT NULL.
  @@unique([organizationId, email])
  @@index([status])
  @@index([sourcedById])
  @@index([locationCity, locationState])
  @@index([currentCompany])
  @@index([seniority])
  @@index([organizationId])
  // Matches the existing "Candidate_searchVector_idx" GIN index created by
  // the manual FTS migration — declared so db push doesn't drop it.
  @@index([searchVector], type: Gin)
}

model Application {
  id          String   @id @default(cuid())
  jobId       String
  candidateId String
  stage       Stage    @default(APPLIED)
  rating      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  job         Job                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate   Candidate            @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  notes       Note[]
  emails      EmailLog[]
  interviews  Interview[]
  enrollments SequenceEnrollment[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateId])
  @@index([jobId, stage])
  @@index([organizationId])
}

/// A note can attach to a specific job application (per-role feedback) or
/// directly to the candidate (general notes for someone not yet on any job).
/// Exactly one of `applicationId` / `candidateId` should be set; we don't
/// enforce that with a DB constraint to keep migrations cheap, the
/// application-layer code (notes-actions.ts) is the source of truth.
model Note {
  id            String    @id @default(cuid())
  applicationId String?
  candidateId   String?
  authorId      String
  body          String
  createdAt     DateTime  @default(now())
  // When set, the note is pinned to the top of the candidate's notes list.
  // Timestamp (rather than a bool) preserves pin-order across multiple pins.
  pinnedAt      DateTime?

  application Application? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  candidate   Candidate?   @relation("CandidateNoteThreads", fields: [candidateId], references: [id], onDelete: Cascade)
  author      User         @relation(fields: [authorId], references: [id])

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([candidateId])
  @@index([organizationId])
}

model KnowledgeItem {
  id          String          @id @default(cuid())
  name        String
  description String?
  // Department this item belongs to: "Sales" | "Recruiting" | "Admin".
  // Nullable for back-compat with rows created before the field existed.
  category    String?
  type        String // "document" | "link"
  // Rich article body — sanitized HTML produced by the portable rich editor
  // (src/components/rich-editor). Nullable; rendered read-only on the article
  // home view and editable in the pop-out editor.
  content     String?
  // Optional primary link/URL. Multiple uploaded documents now live in the
  // KnowledgeAttachment child table; `url` is kept for the single external
  // link case (and back-compat with rows created before attachments existed).
  url         String
  status      KnowledgeStatus @default(UNDER_REVIEW)
  createdById String?
  createdBy   User?           @relation("KnowledgeItemCreator", fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  attachments KnowledgeAttachment[]

  // Optional client this knowledge item belongs to. Auto-set when created
  // from a client's page; chosen (or left as "No client") in the global KB.
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdById])
  @@index([organizationId])
  @@index([clientId])
}

// Files attached to a KnowledgeItem. Many per item — mirrors the
// TaskAttachment pattern. The file blob is stored via lib/uploads
// (Vercel Blob in prod, public/uploads in dev) and `url` points at it.
model KnowledgeAttachment {
  id              String   @id @default(cuid())
  knowledgeItemId String
  name            String
  url             String
  size            Int
  mimeType        String?
  uploadedById    String?
  uploadedAt      DateTime @default(now())

  knowledgeItem KnowledgeItem @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)
  uploadedBy    User?         @relation("KnowledgeAttachmentUploader", fields: [uploadedById], references: [id])

  @@index([knowledgeItemId])
}

model EmailTemplate {
  id            String         @id @default(cuid())
  name          String
  subject       String
  body          String
  createdById   String?
  createdBy     User?          @relation("EmailTemplateCreator", fields: [createdById], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sequenceSteps SequenceStep[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([organizationId])
}

model EmailLog {
  id            String  @id @default(cuid())
  candidateId   String?
  applicationId String?
  // The recruiter ASSOCIATED with this email on our side:
  //   - For OUTBOUND emails: the user who sent it (composer or whose
  //     Outlook the extension captured from).
  //   - For INBOUND emails: the user who clicked "Add to ATS" on the
  //     received email (the "owning" recruiter for the conversation).
  // The actual From: header lives in `fromEmail` below — for INBOUND
  // that's the candidate, which is intentionally different.
  fromUserId    String

  // Actual From: header of the email. Populated for extension captures
  // and future webhook/OAuth captures. Nullable for backwards compat
  // with COMPOSER rows that predate this field.
  fromEmail String?

  to       String
  cc       String[] @default([])
  bcc      String[] @default([])
  replyTo  String?
  subject  String
  bodyText String?
  bodyHtml String?

  // Was this email sent from us or received by us? Defaults to OUTBOUND
  // because that's what every existing composer-sent row is.
  direction EmailDirection @default(OUTBOUND)

  // Where the row came from. Defaults to COMPOSER for the same reason —
  // every existing row was sent via /candidates/[id] composer.
  source EmailSource @default(COMPOSER)

  // RFC 5322 Message-ID header (looks like `<CAJ8x...@mail.gmail.com>`).
  // Globally unique per email. Used to dedupe when the same email is
  // captured via multiple paths (extension click + future webhook).
  // Indexed so dedup lookups are fast.
  messageId String?

  provider          String
  providerMessageId String?
  status            EmailStatus @default(SENT)
  errorMessage      String?

  // Engagement tracking, stamped by the Resend webhook
  // (POST /api/webhooks/resend) keyed on providerMessageId. All nullable;
  // a non-null value means that event happened at that time. firstClickedAt
  // records only the first click (we don't store every click).
  openedAt       DateTime?
  firstClickedAt DateTime?
  repliedAt      DateTime?
  bouncedAt      DateTime?
  complainedAt   DateTime?

  // Wall-clock time the original email was sent/received (from the
  // email's own Date header, not when we ingested it). Falls back to
  // ingestion time when the source can't tell us — e.g. composer rows
  // where sentAt == ingestion time by definition.
  sentAt DateTime @default(now())

  candidate   Candidate?   @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  fromUser    User         @relation(fields: [fromUserId], references: [id])
  stepRun     StepRun?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([candidateId, sentAt])
  @@index([applicationId, sentAt])
  @@index([fromUserId])
  @@index([organizationId])
  @@index([messageId])
  @@index([candidateId, direction, sentAt])
}

/// Channel for a ContactLog entry. The UI lets the recruiter pick one
/// of three when logging (Call, SMS, LinkedIn message), and surfaces it
/// in the history badge alongside Sent/Received.
enum ContactChannel {
  CALL
  SMS
  LINKEDIN
}

/// Disposition of a logged phone call. A single shared field for both
/// outbound ("Log Call") and inbound ("Rec Call") touchpoints — the UI
/// shows the subset of values appropriate to each direction. Values are
/// grouped into "connected" (reached a live person) and "not connected"
/// (no live conversation) so the menu can render Connected on top and Not
/// Connected on the bottom. Only meaningful when channel=CALL.
enum CallOutcome {
  // --- Connected (reached a live person) ---
  CONNECTED
  INTERESTED
  MEETING_BOOKED
  CALLBACK_REQUESTED
  NOT_INTERESTED
  GATEKEEPER
  DO_NOT_CALL
  // --- Not connected (no live conversation) ---
  LEFT_VOICEMAIL
  NO_ANSWER
  BUSY
  WRONG_NUMBER
  NO_LONGER_AT_COMPANY
  MISSED_CALL
}

/// Log of non-email outreach (phone calls, SMS, LinkedIn messages) made
/// to or received from a candidate. Free-form notes — the recruiter types
/// what happened ("Left voicemail, mentioned the open Director role") and
/// hits one of the channel + direction buttons to stamp it. Direction
/// reuses EmailDirection (INBOUND/OUTBOUND) so the UI can render it with
/// the same Sent/Received affordances as email.
model ContactLog {
  id             String         @id @default(cuid())
  candidateId    String
  candidate      Candidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  /// The recruiter who logged this entry.
  loggedByUserId String
  loggedBy       User           @relation("ContactLogLogger", fields: [loggedByUserId], references: [id])
  direction      EmailDirection
  /// Which channel this touchpoint was on. The default (CALL) only matters
  /// for the single pre-channel test row backfilled by `prisma db push` —
  /// every code path that creates new rows explicitly supplies the channel.
  channel        ContactChannel @default(CALL)
  /// Outcome of an outbound call (left vm / no answer / etc). Null for
  /// inbound calls and for SMS/LinkedIn rows.
  outcome        CallOutcome?
  /// Free-form note. Optional — clicking "Log Call → Left VM" is enough on
  /// its own to capture the touchpoint without typing anything.
  notes          String?
  loggedAt       DateTime       @default(now())

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([candidateId, loggedAt])
  @@index([organizationId])
}

model CandidateReference {
  id            String    @id @default(cuid())
  candidateId   String
  firstName     String
  lastName      String
  relationship  String?
  company       String?
  title         String?
  email         String?
  phone         String?
  notes         String?
  contactedAt   DateTime?
  contactedById String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  contactedBy User?     @relation(fields: [contactedById], references: [id])

  @@index([candidateId])
}

// Structured, recruiter-editable education history. The Candidate.education
// Json field above is the raw resume-parser output; these rows are the
// curated layer surfaced on the profile (seedable from that JSON on parse).
model CandidateEducation {
  id              String   @id @default(cuid())
  candidateId     String
  institution     String
  degree          String? // ChoiceOption field="candidate.educationDegree"
  fieldOfStudy    String?
  specialization  String? // concentration / minor (free text)
  startYear       Int?
  endYear         Int? // graduation / expected year
  inProgress      Boolean  @default(false)
  // GPA stored as text on purpose — scales differ by country (4.0, 10.0,
  // First Class, etc.); a numeric column would misrepresent non-US grades.
  gpa             String?
  locationCity    String?
  locationCountry String?
  honors          String? // "Magna cum laude", awards, activities
  notes           String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
}

// Certifications, licenses, clearances, and professional memberships.
model CandidateCertification {
  id                  String    @id @default(cuid())
  candidateId         String
  name                String
  issuingOrganization String?
  kind                String? // ChoiceOption field="candidate.certificationKind"
  credentialId        String? // cert / license number
  credentialUrl       String? // verification link
  jurisdiction        String? // state/country a license is valid in
  issueDate           DateTime?
  expirationDate      DateTime? // null + doesNotExpire = lifetime credential
  doesNotExpire       Boolean   @default(false)
  inProgress          Boolean   @default(false) // pursuing / scheduled
  // Recruiter-confirmed verification (mirrors CandidateReference.contactedBy).
  verifiedAt          DateTime?
  verifiedById        String?
  notes               String?
  sortOrder           Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  candidate  Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  verifiedBy User?     @relation("CertificationVerifier", fields: [verifiedById], references: [id])

  @@index([candidateId])
  // "Active / Expired / Expiring soon" is derived from expirationDate rather
  // than stored (a stored status goes stale the day a cert lapses); index it
  // so "certs expiring in N days" stays a cheap query.
  @@index([expirationDate])
}

model CandidateDocument {
  id           String       @id @default(cuid())
  candidateId  String
  type         DocumentType
  name         String
  url          String
  notes        String?
  uploadedById String?
  uploadedAt   DateTime     @default(now())

  candidate  Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  uploadedBy User?     @relation(fields: [uploadedById], references: [id])

  @@index([candidateId])
  @@index([candidateId, type])
}

// EEO data is legally sensitive; gate access at the application layer
// and never join into search/match logic.
model CandidateEEO {
  id               String            @id @default(cuid())
  candidateId      String            @unique
  gender           Gender?
  race             String?
  veteranStatus    VeteranStatus?
  disabilityStatus DisabilityStatus?
  providedAt       DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model CandidateActivity {
  id          String   @id @default(cuid())
  candidateId String
  type        String
  description String?
  metadata    Json?
  userId      String?
  createdAt   DateTime @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])

  @@index([candidateId, createdAt])
}

// Shared admin task list. Description stores raw HTML — writers and readers
// are both admins (gated in the route), so the trust boundary makes this safe.
model Task {
  id           String        @id @default(cuid())
  name         String
  description  String?
  status       TaskStatus    @default(NOT_STARTED)
  priority     TaskPriority?
  dueDate      DateTime?
  createdById  String?
  createdBy    User?         @relation("TaskCreator", fields: [createdById], references: [id])
  assignedToId String?
  assignedTo   User?         @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  attachments TaskAttachment[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([assignedToId])
  @@index([dueDate])
  @@index([updatedAt])
  @@index([createdAt])
  @@index([organizationId])
}

model TaskAttachment {
  id           String   @id @default(cuid())
  taskId       String
  name         String
  url          String
  size         Int
  mimeType     String?
  uploadedById String?
  uploadedAt   DateTime @default(now())

  task       Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User? @relation("TaskAttachmentUploader", fields: [uploadedById], references: [id])

  @@index([taskId])
}

// Recruiter-curated candidate lists ("Active Engineering", "Cold pipeline 2026", etc).
// Personal lists are visible to their owner only; SHARED lists are visible to all users.
model CandidateList {
  id          String    @id @default(cuid())
  name        String
  description String?
  ownerId     String
  scope       ListScope @default(PERSONAL)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner     User                    @relation(fields: [ownerId], references: [id])
  members   CandidateListMember[]
  jobs      CandidateListJob[]
  assignees CandidateListAssignee[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([scope])
  @@index([organizationId])
}

// Links a list to one or more jobs (many-to-many). Informational association
// shown on /lists and editable on the list detail page.
model CandidateListJob {
  id      String   @id @default(cuid())
  listId  String
  jobId   String
  addedAt DateTime @default(now())

  list CandidateList @relation(fields: [listId], references: [id], onDelete: Cascade)
  job  Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([listId, jobId])
  @@index([jobId])
}

// Assigns a list to one or more teammates (many-to-many). Label-only — does
// NOT grant visibility or edit rights; the PERSONAL/SHARED scope still governs
// access.
model CandidateListAssignee {
  id           String   @id @default(cuid())
  listId       String
  userId       String
  assignedById String?
  assignedAt   DateTime @default(now())

  list       CandidateList @relation(fields: [listId], references: [id], onDelete: Cascade)
  user       User          @relation("ListAssignee", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy User?         @relation("ListAssigner", fields: [assignedById], references: [id])

  @@unique([listId, userId])
  @@index([userId])
}

model CandidateListMember {
  id          String   @id @default(cuid())
  listId      String
  candidateId String
  addedById   String?
  addedAt     DateTime @default(now())

  list      CandidateList @relation(fields: [listId], references: [id], onDelete: Cascade)
  candidate Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  addedBy   User?         @relation("ListMemberAdder", fields: [addedById], references: [id])

  @@unique([listId, candidateId])
  @@index([candidateId])
}

// A named, reusable filter set on /candidates. paramsString stores the raw
// URL query (e.g. "q=react&status=ACTIVE,PASSIVE&tag=Senior") so loading a
// saved search is a navigation to ?<paramsString>.
model SavedSearch {
  id           String           @id @default(cuid())
  name         String
  ownerId      String
  scope        SavedSearchScope @default(PERSONAL)
  paramsString String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  owner User @relation(fields: [ownerId], references: [id])

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([scope])
  @@index([organizationId])
}

// A saved layout for the candidate-detail Profile section: which editable
// fields are shown and in what order/section. Personal (owner-only) or shared
// (whole org). The "working" layout lives in localStorage; these are the
// named, cross-device ones. config is JSON: { sections: [{ title, fields }] }.
model ProfileLayout {
  id             String           @id @default(cuid())
  name           String
  scope          SavedSearchScope @default(PERSONAL)
  config         String
  ownerId        String
  owner          User             @relation(fields: [ownerId], references: [id])
  organizationId String?
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([ownerId])
  @@index([organizationId])
}

model Interview {
  id            String          @id @default(cuid())
  applicationId String?
  candidateId   String
  title         String
  type          InterviewType
  status        InterviewStatus @default(SCHEDULED)
  startAt       DateTime
  endAt         DateTime
  timezone      String?
  location      String?
  videoUrl      String?
  description   String?
  organizerId   String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  application Application?        @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  candidate   Candidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  organizer   User                @relation("InterviewOrganizer", fields: [organizerId], references: [id])
  attendees   InterviewAttendee[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([candidateId, startAt])
  @@index([organizerId, startAt])
  @@index([startAt])
  @@index([status])
  @@index([organizationId])
}

model InterviewAttendee {
  id          String  @id @default(cuid())
  interviewId String
  userId      String?
  email       String
  name        String?
  role        String?

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  user      User?     @relation("InterviewAttendeeUser", fields: [userId], references: [id])

  @@index([interviewId])
  @@index([userId])
}

// User-editable lookup registry for "soft" choice fields (Candidate.source,
// Candidate.seniority, etc). The candidate column stores the option's `name`
// directly — rename is an updateMany, delete sets affected records to null.
model ChoiceOption {
  id        String   @id @default(cuid())
  field     String
  name      String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Per-org uniqueness. The old global @@unique([field, name]) meant the
  // first org to seed a field's defaults blocked every other org's seeding
  // (createMany skipDuplicates silently dropped all rows), leaving later
  // workspaces with empty choice lists.
  @@unique([organizationId, field, name])
  @@index([field, active, sortOrder])
  @@index([organizationId])
}

// ----- Sequences (multi-step cadences) -----

model Sequence {
  id          String         @id @default(cuid())
  name        String
  description String?
  status      SequenceStatus @default(ACTIVE)
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  createdBy   User?                @relation("SequenceCreator", fields: [createdById], references: [id])
  steps       SequenceStep[]
  enrollments SequenceEnrollment[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdById])
  @@index([organizationId])
}

model SequenceStep {
  id         String           @id @default(cuid())
  sequenceId String
  order      Int
  type       SequenceStepType
  delayDays  Int              @default(0)

  // EMAIL-only
  emailTemplateId String?
  subject         String?
  body            String?

  // Manual-task-only (CALL/TEXT/LINKEDIN/TASK)
  taskTitle        String?
  taskInstructions String?

  sequence      Sequence       @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  emailTemplate EmailTemplate? @relation(fields: [emailTemplateId], references: [id], onDelete: SetNull)
  runs          StepRun[]

  @@unique([sequenceId, order])
  @@index([sequenceId])
}

model SequenceEnrollment {
  id             String           @id @default(cuid())
  sequenceId     String
  candidateId    String
  applicationId  String?
  enrolledById   String?
  status         EnrollmentStatus @default(ACTIVE)
  startedAt      DateTime         @default(now())
  pausedAt       DateTime?
  completedAt    DateTime?
  // Why the engine auto-paused this enrollment (candidate replied, bounced,
  // or complained). Null for manual pauses. Surfaced in the enrollments UI.
  autoStopReason String?

  sequence    Sequence     @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  candidate   Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  enrolledBy  User?        @relation("SequenceEnroller", fields: [enrolledById], references: [id])
  stepRuns    StepRun[]

  @@unique([sequenceId, candidateId])
  @@index([candidateId])
  @@index([status])
  @@index([enrolledById, status])
}

model StepRun {
  id           String        @id @default(cuid())
  enrollmentId String
  stepId       String
  scheduledFor DateTime
  status       StepRunStatus @default(PENDING)

  // EMAIL only
  emailLogId        String? @unique
  resendScheduledId String?

  // Manual task only
  completedAt   DateTime?
  completedById String?
  outcomeNote   String?

  errorMessage String?

  enrollment  SequenceEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  step        SequenceStep       @relation(fields: [stepId], references: [id], onDelete: Cascade)
  emailLog    EmailLog?          @relation(fields: [emailLogId], references: [id], onDelete: SetNull)
  completedBy User?              @relation("StepRunCompleter", fields: [completedById], references: [id])

  @@index([scheduledFor, status])
  @@index([enrollmentId])
}

// ----- AI assistant -----
//
// Conversation = one chat thread between a user and the assistant.
// Message = one turn in that thread (user / assistant / tool / system).
// ToolCall = an audit row for every tool the assistant invoked, including
// args + result + any error, so we can replay and review what the AI did.

enum AssistantRole {
  USER
  ASSISTANT
  TOOL
  SYSTEM
}

model AssistantConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User               @relation("AssistantUser", fields: [userId], references: [id])
  messages AssistantMessage[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@index([organizationId])
}

model AssistantMessage {
  id             String        @id @default(cuid())
  conversationId String
  role           AssistantRole
  content        String
  // For assistant turns that requested tool calls. Shape:
  //   [{ id: string, name: string, arguments: object }]
  toolCalls      Json?
  // For TOOL messages: which assistant tool_call id this is a response to.
  toolCallId     String?
  createdAt      DateTime      @default(now())

  conversation  AssistantConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolAuditLogs AssistantToolCall[]

  @@index([conversationId, createdAt])
}

model AssistantToolCall {
  id           String   @id @default(cuid())
  messageId    String
  userId       String
  toolName     String
  arguments    Json
  result       Json?
  isError      Boolean  @default(false)
  errorMessage String?
  createdAt    DateTime @default(now())

  message AssistantMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User             @relation("AssistantToolCaller", fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([toolName])
}

// Admin-managed custom fields. Definitions live in CustomField (one row per
// (entity, key)), and the actual values per record live in CustomFieldValue.
// CustomFieldValue.entityId is intentionally untyped (polymorphic) — the
// record-deletion paths in each entity's actions.ts are responsible for
// cleaning up orphaned values.
enum CustomFieldEntity {
  CLIENT
  CLIENT_CONTACT
  CANDIDATE
  INTERVIEW
  TASK
  JOB
  USER
}

enum CustomFieldType {
  TEXT
  LONG_TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTI_SELECT
  URL
  EMAIL
}

model CustomField {
  id        String            @id @default(cuid())
  entity    CustomFieldEntity
  key       String
  label     String
  type      CustomFieldType
  helpText  String?
  required  Boolean           @default(false)
  // Used only when type is SELECT or MULTI_SELECT.
  options   String[]          @default([])
  sortOrder Int               @default(0)
  active    Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  values CustomFieldValue[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Per-tenant uniqueness — each org has its own namespace of field keys,
  // so two workspaces can independently define e.g. (CANDIDATE, "company_state")
  // without colliding.
  @@unique([organizationId, entity, key])
  @@index([entity, active, sortOrder])
  @@index([organizationId])
}

model CustomFieldValue {
  id           String    @id @default(cuid())
  fieldId      String
  entityId     String
  valueText    String?
  valueNumber  Float?
  valueDate    DateTime?
  valueBoolean Boolean?
  valueStrings String[]  @default([])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  field CustomField @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, entityId])
  @@index([entityId])
}

/// Append-only audit trail. Captured automatically for allowlisted models
/// via the Prisma extension in `src/lib/audit/extension.ts`, plus explicit
/// `recordAuditEvent(...)` calls for non-CRUD events (login, role change,
/// token mint, AI config change, ...).
///
/// `organizationId` is null for platform-scope events (e.g. an org getting
/// created, a platform admin doing cross-tenant work). Otherwise it carries
/// the same tenant scope as the entity being audited so per-tenant queries
/// can filter on a single column + the (organizationId, createdAt) index.
///
/// `actorUserId` is nullable so we can log events triggered without a
/// human (cron jobs, system processes). `actorEmail` is a snapshot so
/// deleted/deactivated users still show in historical logs.
///
/// Field-level skips: `passwordHash` and any field whose name is on the
/// SKIP list in the extension are dropped from the diff. The whole
/// `CandidateEEO` model is excluded — EEO data is legally gated separately.
model AuditLog {
  id             String        @id @default(cuid())
  createdAt      DateTime      @default(now())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  actorUserId String?
  actorUser   User?   @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorEmail  String?

  action AuditAction

  // For CRUD events: the model name (e.g. "Candidate") and primary key.
  // Null for non-CRUD events like LOGIN.
  entityType  String?
  entityId    String?
  // Human-friendly snapshot of the entity at the time of the event — name,
  // title, or short body — so deleted entities still read nicely in logs.
  entityLabel String?

  // List of field names that changed in an UPDATE, in their canonical
  // model-field naming. Empty for CREATE/DELETE/non-CRUD events.
  changedFields String[] @default([])

  // Field-level diff for UPDATEs: { fieldName: { before, after } }.
  // For DELETE the snapshot is in `before` per field. Each value is
  // truncated to ~2 KB by the extension to keep the table sane.
  diff Json?

  // Free-form for non-CRUD events (e.g. `{ targetUserId, oldRole, newRole }`
  // for a ROLE_CHANGE). Also carries the truncation marker when diff fields
  // were dropped for size.
  metadata Json?

  // Request fingerprints — best-effort. Stored as snapshot strings.
  ip        String?
  userAgent String?

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([action])
}

// ----- Workspace announcements -----
//
// Admins and platform admins post short messages that surface on every
// user's dashboard in a rotating banner. Three audiences:
//   OWN_ORG          — tenant admin, visible only inside their org
//   ALL_TENANTS      — platform admin, visible everywhere
//   SELECTED_TENANTS — platform admin, visible only to specific orgs
//
// `active` is the kill-switch (the "decide what shows" toggle in the console)
// so an announcement can be drafted, paused, or retired without deleting it.

enum AnnouncementAudience {
  OWN_ORG
  ALL_TENANTS
  SELECTED_TENANTS
}

model Announcement {
  id             String               @id @default(cuid())
  title          String?
  body           String
  audience       AnnouncementAudience
  active         Boolean              @default(true)
  createdById    String
  // Only set when audience = OWN_ORG. Null for the two platform scopes.
  organizationId String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  createdBy    User                 @relation("AnnouncementAuthor", fields: [createdById], references: [id])
  organization Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  targets      AnnouncementTarget[]

  @@index([audience, active])
  @@index([organizationId, active])
}

model AnnouncementTarget {
  id             String @id @default(cuid())
  announcementId String
  organizationId String

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([announcementId, organizationId])
  @@index([organizationId])
}

/**
 * Saved CSV-import mapping, keyed by a sha256 fingerprint of the file's
 * sorted-normalized headers. When the next file with the same header set
 * is uploaded, the importer restores the previously-saved mapping (field
 * pairings, new-field creation choices, value-merge decisions, etc.) so
 * teammates don't have to redo the work. One row per (org, fingerprint).
 */
model ImportMapping {
  id                 String   @id @default(cuid())
  organizationId     String
  headersFingerprint String
  // Canonical-field-key -> input header (or null = skip). Also captures
  // any `cf:<fieldId>` keys once we surface existing custom fields.
  mapping            Json
  // Per-header new-field drafts: { header: { create, label, type } }.
  newFieldDrafts     Json
  // User merges resolving fuzzy near-duplicate options for choice fields.
  userMerges         Json
  // Per-header confirmation flags for high-cardinality choice fields.
  confirmHigh        Json
  createdById        String?
  updatedById        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("ImportMappingCreator", fields: [createdById], references: [id])
  updatedBy    User?        @relation("ImportMappingUpdater", fields: [updatedById], references: [id])

  @@unique([organizationId, headersFingerprint])
  @@index([organizationId])
}

/// One named CSV import run. Captures the user-supplied name (required at
/// import), who ran it, when, the on-match mode, and per-run counts. Each
/// candidate the run CREATES points back here via Candidate.importId.
model CandidateImport {
  id             String   @id @default(cuid())
  organizationId String
  // User-supplied label for this import (required in the UI).
  name           String
  // "create" | "upsert" | "update-only" — what the run did on email match.
  mode           String   @default("create")
  createdCount   Int      @default(0)
  updatedCount   Int      @default(0)
  skippedCount   Int      @default(0)
  erroredCount   Int      @default(0)
  // Who ran the import. Nullable so the run survives the user being deleted.
  importedById   String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  importedBy   User?        @relation("CandidateImporter", fields: [importedById], references: [id])
  candidates   Candidate[]

  @@index([organizationId, createdAt])
}
